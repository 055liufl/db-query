# OpenAI API key (Phase 3 natural language SQL)
OPENAI_API_KEY=
# Optional API base URL (omit = default https://api.openai.com/v1). Examples: proxy, Azure OpenAI endpoint.
OPENAI_BASE_URL=
# Chat model id (must be allowed by your provider; default gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# SQLite directory for connection + metadata cache (default: ~/.db_query)
DB_QUERY_PATH=
