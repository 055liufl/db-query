# Test image for docker-compose.test.yml (avoids build.target on old docker-compose).
# Keep in sync with Dockerfile stages: base + test.
FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PIP_PROGRESS_BAR=off
ENV PIP_DEFAULT_TIMEOUT=600
ENV PIP_DISABLE_PIP_VERSION_CHECK=1
ENV PIP_REQUIRE_HASHES=0
ENV PIP_CONSTRAINT=

ARG PIP_INDEX_URL=https://pypi.org/simple
ARG PIP_TRUSTED_HOST=

COPY pyproject.toml .
COPY app ./app
COPY tests ./tests

RUN set -e; \
    EXTRA=""; \
    if [ -n "$PIP_TRUSTED_HOST" ]; then EXTRA="--trusted-host $PIP_TRUSTED_HOST"; fi; \
    pip install --no-cache-dir --progress-bar off --default-timeout 600 --retries 20 \
        -i "${PIP_INDEX_URL}" $EXTRA .

RUN set -e; \
    EXTRA=""; \
    if [ -n "$PIP_TRUSTED_HOST" ]; then EXTRA="--trusted-host $PIP_TRUSTED_HOST"; fi; \
    pip install --no-cache-dir --progress-bar off --default-timeout 600 --retries 20 \
        -i "${PIP_INDEX_URL}" $EXTRA ".[dev]"

CMD ["python", "-m", "pytest", "-q"]
